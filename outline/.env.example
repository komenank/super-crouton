# ── Outline ───────────────────────────────────────────────────────────────────
OUTLINE_PORT=13001

# Public URL — must match the URL Outline is served from (used for OAuth redirects)
URL=https://wiki.example.com

# Generate with: openssl rand -hex 32
SECRET_KEY=changeme
UTILS_SECRET=changeme

# Set to false when terminating TLS at a reverse proxy / Cloudflare Tunnel
FORCE_HTTPS=false

# ── Database ───────────────────────────────────────────────────────────────────
POSTGRES_USER=outline
POSTGRES_PASSWORD=changeme
POSTGRES_DB=outline

DATABASE_URL=postgres://outline:changeme@postgres:5432/outline
PGSSLMODE=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── File storage ──────────────────────────────────────────────────────────────
FILE_STORAGE=local
FILE_STORAGE_LOCAL_ROOT_DIR=/var/lib/outline/data
# Max upload size in bytes (default 250 MB)
FILE_STORAGE_UPLOAD_MAX_SIZE=262144000

# ── Keycloak OIDC ─────────────────────────────────────────────────────────────
# Register a client in Keycloak with:
#   - Client ID matching OIDC_CLIENT_ID
#   - Valid redirect URI: ${URL}/auth/oidc.callback
OIDC_CLIENT_ID=outline
OIDC_CLIENT_SECRET=changeme
OIDC_AUTH_URI=https://auth.example.com/realms/master/protocol/openid-connect/auth
OIDC_TOKEN_URI=https://auth.example.com/realms/master/protocol/openid-connect/token
OIDC_USERINFO_URI=https://auth.example.com/realms/master/protocol/openid-connect/userinfo
OIDC_DISPLAY_NAME=Keycloak
OIDC_SCOPES=openid profile email
