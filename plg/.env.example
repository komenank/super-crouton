# ── Grafana ──────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=changeme
GF_PORT=13000
GF_TIMEZONE=America/New_York # https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
# Public URL — used for OAuth redirects, links in alerts, etc.
# If you expose Grafana through Cloudflare Tunnels, set this to the public URL.
GF_ROOT_URL=https://logs.example.com
